<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import java.net.URL?>
<VBox prefHeight="240.0" prefWidth="260.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.database.AddLineController">
    <stylesheets>
        <URL value="@styles.css" />
    </stylesheets>
   <children>
      <GridPane prefHeight="149.0" prefWidth="260.0">
          <columnConstraints>
              <ColumnConstraints hgrow="SOMETIMES" maxWidth="116.0" minWidth="10.0" prefWidth="59.0" />
              <ColumnConstraints maxWidth="208.8" minWidth="127.19999618530272" prefWidth="201.8" />
          </columnConstraints>
          <rowConstraints>
              <RowConstraints maxHeight="40.0" minHeight="9.4" prefHeight="9.4" vgrow="SOMETIMES" />
              <RowConstraints maxHeight="158.40000381469727" minHeight="0.0" prefHeight="30.6" />
              <RowConstraints />
              <RowConstraints />
              <RowConstraints />
              <RowConstraints />
          </rowConstraints>
          <children>
              <Label alignment="CENTER" prefHeight="18.0" prefWidth="63.0" text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
              <TextField fx:id="idField" maxWidth="190.0" prefHeight="44.0" prefWidth="190.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

              <Label alignment="CENTER" prefHeight="18.0" prefWidth="61.0" text="Имя:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
              <TextField fx:id="nameField" maxWidth="190.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

              <Label alignment="CENTER" prefHeight="18.0" prefWidth="63.0" text="Фамилия:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
              <TextField fx:id="surnameField" maxWidth="190.0" prefHeight="29.0" prefWidth="190.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

              <Label alignment="CENTER" prefHeight="18.0" prefWidth="62.0" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
              <TextField fx:id="emailField" maxWidth="190.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

              <Label alignment="CENTER" prefHeight="18.0" prefWidth="65.0" text="Телефон:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
              <TextField fx:id="phoneField" maxWidth="190.0" prefHeight="17.0" prefWidth="147.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
          </children>
      </GridPane>
      <Label alignment="CENTER" prefHeight="53.0" prefWidth="260.0" text="Введите данные для создания новой строки" textAlignment="CENTER">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
      <Button fx:id="createPerson" mnemonicParsing="false" prefHeight="26.0" prefWidth="280.0" text="Создать" onAction="#handleCreate" />
   </children>
</VBox>
